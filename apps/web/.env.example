# -----------------------------------------------------------------------
# Bitcoin Academy — Frontend environment variables
# Copy this file to .env.local and fill in the values before starting.
# -----------------------------------------------------------------------

# --- Backend API -------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# --- NextAuth.js -------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-must-be-at-least-32-chars-long
