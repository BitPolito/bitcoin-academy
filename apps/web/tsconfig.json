{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "jsx": "preserve",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/components/*": [
                "./src/components/*"
            ],
            "@/lib/*": [
                "./src/lib/*"
            ],
            "@/app/*": [
                "./src/app/*"
            ]
        },
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "incremental": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "src/**/*",
        "src/**/*.tsx",
        "src/**/*.ts",
        "src/globals.d.ts",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build",
        ".next"
    ]
}