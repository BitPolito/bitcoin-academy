# -----------------------------------------------------------------------
# Bitcoin Academy — Backend environment variables
# Copy this file to .env and fill in the values before starting.
# -----------------------------------------------------------------------

# --- Database (required) -----------------------------------------------
# Use PostgreSQL in development and production.
# SQLite is supported for quick local testing only (no concurrent writes).
DATABASE_URL=postgresql://user:password@localhost:5432/bitcoin_academy

# --- Auth / JWT (required) ---------------------------------------------
SECRET_KEY=change-me-must-be-at-least-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Runtime -----------------------------------------------------------
ENVIRONMENT=development          # development | production
API_PORT=8000

# --- CORS (required in production) -------------------------------------
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000

# --- ALLOWED_HOSTS (production only) -----------------------------------
# ALLOWED_HOSTS=academy.example.com

# --- AI / LLM (optional — system works without it; generation actions return fallback text) ---
OPENAI_API_KEY=

# --- ChromaDB (local vector store path) ----------------------------------------
# MUST be an absolute path. A relative path causes read/write to diverge when
# uvicorn is started from a directory other than services/ai/.
# Example (adjust to your machine):
CHROMA_DB_PATH=/absolute/path/to/bitcoin-academy/services/ai/chroma_db

# --- Retrieval tuning ----------------------------------------------------------
RAG_TOP_K=10

# --- LLM generation timeout (seconds) -----------------------------------------
LLM_TIMEOUT_SECONDS=30

# --- Debug mode (enables /api/debug/* endpoints — never enable in production) ---
DEBUG_MODE=false

# --- QVAC integration (optional — bypassed when QVAC_SERVICE_URL is unset) ------
QVAC_SERVICE_URL=http://localhost:3001

# Directory where pipeline.py writes JSONL files for QVAC to read
QVAC_INGEST_DIR=./qvac_ingest

# File upload storage
UPLOADS_DIR=./uploads

# ChromaDB collection name — must match exactly across pipeline.py and retrieval_service.py
CHROMA_COLLECTION_NAME=bitpolito_course

# Max evidence chunks returned to the study endpoint
RAG_MAX_EVIDENCE=6
